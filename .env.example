# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must never be committed.

# Server-side SMTP credentials for OTP email (e.g. a Gmail app password)
EMAIL_USER=your-smtp-username@gmail.com
EMAIL_PASS=your-smtp-app-password

# App
NEXT_PUBLIC_URL=http://localhost:3000

# MongoDB connection string (database "meripanchayat" is appended in code)
DB_URL=your-mongodb-connection-string

# EdgeStore file storage
EDGE_STORE_ACCESS_KEY=your-edgestore-access-key
EDGE_STORE_SECRET_KEY=your-edgestore-secret-key
